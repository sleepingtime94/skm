{% extends 'layout.twig' %}
{% block content %}
<!-- Mobile Overlay -->
<div id="sidebar-overlay" class="sidebar-overlay"></div>

<div class="dash-wrapper">
    <!-- ═══ Sidebar ═══════════════════════════════════════════ -->
    <aside class="dash-sidebar" id="dash-sidebar">
        <div class="brand">
            <div class="brand-icon"><i class="bi bi-patch-check-fill"></i></div>
            <div class="brand-text">
                Disdukcapil
                <small>Kabupaten Tapin</small>
            </div>
        </div>

        <div class="nav-section">
            <div class="nav-label">Menu Utama</div>
            <a class="nav-item active" data-page="overview" href="#">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>
            <a class="nav-item" data-page="employees" href="#">
                <i class="bi bi-people-fill"></i> Kelola Pegawai
            </a>
            <a class="nav-item" data-page="ratings" href="#">
                <i class="bi bi-star-fill"></i> Penilaian Pegawai
            </a>

            <div class="nav-label mt-3">Data Survei</div>
            <a class="nav-item" data-page="skm" href="#">
                <i class="bi bi-chat-heart-fill"></i> Survei SKM
            </a>
            <a class="nav-item" data-page="zi" href="#">
                <i class="bi bi-shield-fill-check"></i> Survei ZI
            </a>
        </div>

        <div class="nav-footer">
            <form action="/logout" method="POST" id="logout-form" style="margin:0;">
                <input type="hidden" name="_csrf" value="{{ session.csrf_token }}">
                <button type="submit" class="nav-item text-danger"
                    style="border-left:0;padding:.5rem 0;width:100%;background:none;border-top:0;border-right:0;border-bottom:0;text-align:left;cursor:pointer;">
                    <i class="bi bi-box-arrow-left"></i> Keluar
                </button>
            </form>
        </div>
    </aside>

    <!-- ═══ Main ══════════════════════════════════════════════ -->
    <div class="dash-main">
        <!-- Topbar -->
        <div class="dash-topbar">
            <div class="d-flex align-items-center gap-3">
                <button id="sidebar-toggle" class="sidebar-toggle"><i class="bi bi-list"></i></button>
                <span class="page-title" id="page-title">Dashboard</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <a href="/" class="btn btn-sm btn-outline-secondary"><i class="bi bi-house me-1"></i>Beranda</a>
            </div>
        </div>

        <!-- Content Area -->
        <div class="dash-content">

            <!-- ── OVERVIEW PAGE ─────────────────────────────── -->
            <div class="dash-page active" id="page-overview">
                <!-- Stat Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-lg-3">
                        <div class="info-box">
                            <div class="icon-box bg-primary-subtle text-primary"><i class="bi bi-people-fill"></i></div>
                            <div class="info-body">
                                <div class="label">Total Pegawai</div>
                                <div class="value text-primary" id="ov-total-emp">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="info-box">
                            <div class="icon-box bg-info-subtle text-info"><i class="bi bi-clipboard-data-fill"></i>
                            </div>
                            <div class="info-body">
                                <div class="label">Total Penilaian</div>
                                <div class="value text-info" id="ov-total-rat">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="info-box">
                            <div class="icon-box bg-success-subtle text-success"><i
                                    class="bi bi-hand-thumbs-up-fill"></i></div>
                            <div class="info-body">
                                <div class="label">Penilaian Bagus</div>
                                <div class="value text-success" id="ov-bagus">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="info-box">
                            <div class="icon-box bg-danger-subtle text-danger"><i
                                    class="bi bi-hand-thumbs-down-fill"></i></div>
                            <div class="info-body">
                                <div class="label">Penilaian Buruk</div>
                                <div class="value text-danger" id="ov-buruk">—</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Panels -->
                <div class="row g-3">
                    <div class="col-lg-6">
                        <div class="section-card h-100">
                            <div class="section-header">
                                <h5><i class="bi bi-trophy-fill text-warning me-2"></i>Pegawai Terbaik</h5>
                            </div>
                            <div class="section-body" id="ov-top-employees">
                                <div class="text-muted small text-center py-3">Memuat…</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="section-card h-100">
                            <div class="section-header">
                                <h5><i class="bi bi-clock-history text-primary me-2"></i>Penilaian Terbaru</h5>
                            </div>
                            <div class="section-body" id="ov-recent-ratings">
                                <div class="text-muted small text-center py-3">Memuat…</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── EMPLOYEES PAGE ────────────────────────────── -->
            <div class="dash-page" id="page-employees">
                <div class="section-card mb-4">
                    <div class="section-header">
                        <h5><i class="bi bi-people-fill text-primary me-2"></i>Daftar Pegawai</h5>
                        <div class="d-flex gap-2 flex-wrap">
                            <input type="text" id="emp-search" class="form-control form-control-sm"
                                placeholder="Cari nama…" style="max-width:180px;" oninput="renderEmployees()">
                            <select id="emp-filter-job" class="form-select form-select-sm" style="max-width:150px;"
                                onchange="renderEmployees()">
                                <option value="">Semua Jabatan</option>
                                <option value="FO">Front Office</option>
                                <option value="FD">Front Desk</option>
                                <option value="OPR">Operator</option>
                                <option value="NONE">Tidak Ada</option>
                            </select>
                            <button class="btn btn-sm btn-primary" onclick="showAddEmployee()">
                                <i class="bi bi-plus-lg me-1"></i>Tambah
                            </button>
                        </div>
                    </div>
                    <div class="section-body no-pad">
                        <div class="table-responsive">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th class="ps-3">Nama</th>
                                        <th>NIP</th>
                                        <th>Jabatan/Posisi</th>
                                        <th class="text-center">Tugas</th>
                                        <th>Keterangan</th>
                                        <th class="text-center pe-3">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="emp-tbody">
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Memuat…</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-top">
                            <div class="text-muted small" id="emp-page-info"></div>
                            <nav>
                                <ul class="pagination pagination-sm mb-0 gap-1" id="emp-pagination"></ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── RATINGS PAGE ──────────────────────────────── -->
            <div class="dash-page" id="page-ratings">
                <!-- Summary Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="info-box">
                            <div class="icon-box bg-primary-subtle text-primary"><i
                                    class="bi bi-clipboard-data-fill"></i></div>
                            <div class="info-body">
                                <div class="label">Total</div>
                                <div class="value text-primary" id="rat-total">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-box">
                            <div class="icon-box bg-success-subtle text-success"><i
                                    class="bi bi-hand-thumbs-up-fill"></i></div>
                            <div class="info-body">
                                <div class="label">Bagus (5★)</div>
                                <div class="value text-success" id="rat-bagus">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-box">
                            <div class="icon-box bg-info-subtle text-info"><i class="bi bi-hand-thumbs-up"></i></div>
                            <div class="info-body">
                                <div class="label">Lumayan (3★)</div>
                                <div class="value text-info" id="rat-lumayan">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-box">
                            <div class="icon-box bg-danger-subtle text-danger"><i
                                    class="bi bi-hand-thumbs-down-fill"></i></div>
                            <div class="info-body">
                                <div class="label">Buruk (1★)</div>
                                <div class="value text-danger" id="rat-buruk">—</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Per-Employee Stats -->
                <div class="section-card mb-4">
                    <div class="section-header">
                        <h5><i class="bi bi-bar-chart-fill text-primary me-2"></i>Statistik per Pegawai</h5>
                        <button class="btn btn-sm btn-outline-primary" onclick="loadRatings()"><i
                                class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
                    </div>
                    <div class="section-body" id="rat-employee-stats">
                        <div class="text-muted small text-center py-3">Memuat…</div>
                    </div>
                </div>

                <!-- Rating Table -->
                <div class="section-card">
                    <div class="section-header">
                        <h5><i class="bi bi-table text-primary me-2"></i>Riwayat Penilaian</h5>
                        <div class="d-flex gap-2">
                            <input type="text" id="rat-search" class="form-control form-control-sm"
                                placeholder="Cari pegawai…" style="max-width:180px;" oninput="renderRatingTable()">
                            <select id="rat-filter-val" class="form-select form-select-sm" style="max-width:140px;"
                                onchange="renderRatingTable()">
                                <option value="">Semua Nilai</option>
                                <option value="5">Bagus (5★)</option>
                                <option value="3">Lumayan (3★)</option>
                                <option value="1">Buruk (1★)</option>
                            </select>
                        </div>
                    </div>
                    <div class="section-body no-pad">
                        <div class="table-responsive">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th class="ps-3">Tanggal</th>
                                        <th>Nama Pegawai</th>
                                        <th>Jabatan</th>
                                        <th class="text-center">Nilai</th>
                                        <th class="text-center pe-3">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="rat-tbody">
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">Memuat…</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-top">
                            <div class="text-muted small" id="rat-page-info"></div>
                            <nav>
                                <ul class="pagination pagination-sm mb-0 gap-1" id="rat-pagination"></ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── SKM PAGE ──────────────────────────────────── -->
            <div class="dash-page" id="page-skm">
                <div class="section-card">
                    <div class="section-header">
                        <h5><i class="bi bi-chat-heart-fill text-primary me-2"></i>Data Survei SKM</h5>
                        <div class="d-flex gap-2 align-items-end flex-wrap">
                            <select id="skm-month" class="form-select form-select-sm" style="max-width:130px;">
                                {% for i in 1..12 %}
                                <option value="{{ i }}" {{ i==('now'|date('n')) ? 'selected' : '' }}>
                                    {{ date('2025-' ~ i ~ '-01')|date('F') }}
                                </option>
                                {% endfor %}
                            </select>
                            <select id="skm-year" class="form-select form-select-sm" style="max-width:100px;">
                                {% for y in range(2025, date()|date('Y')) %}
                                <option value="{{ y }}" {{ y==('now'|date('Y')) ? 'selected' : '' }}>{{ y }}</option>
                                {% endfor %}
                            </select>
                            <button class="btn btn-sm btn-primary" onclick="loadSKM()"><i
                                    class="bi bi-funnel me-1"></i>Filter</button>
                        </div>
                    </div>
                    <div class="section-body no-pad">
                        <div class="table-responsive">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th>Tgl.</th>
                                        <th>Nama</th>
                                        <th>Kontak</th>
                                        <th>Umur</th>
                                        <th>Pendidikan</th>
                                        <th>Pekerjaan</th>
                                        <th>Layanan</th>
                                        {% for i in 1..9 %}<th class="text-center">K{{ i }}</th>{% endfor %}
                                    </tr>
                                </thead>
                                <tbody id="skm-tbody">
                                    <tr>
                                        <td colspan="16" class="text-center py-4 text-muted">Klik Filter untuk memuat
                                            data.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── ZI PAGE ───────────────────────────────────── -->
            <div class="dash-page" id="page-zi">
                <div class="section-card">
                    <div class="section-header">
                        <h5><i class="bi bi-shield-fill-check text-success me-2"></i>Data Survei Zona Integritas</h5>
                        <div class="d-flex gap-2 align-items-end flex-wrap">
                            <select id="zi-month" class="form-select form-select-sm" style="max-width:130px;">
                                {% for i in 1..12 %}
                                <option value="{{ i }}" {{ i==('now'|date('n')) ? 'selected' : '' }}>
                                    {{ date('2025-' ~ i ~ '-01')|date('F') }}
                                </option>
                                {% endfor %}
                            </select>
                            <select id="zi-year" class="form-select form-select-sm" style="max-width:100px;">
                                {% for y in range(2025, date()|date('Y')) %}
                                <option value="{{ y }}" {{ y==('now'|date('Y')) ? 'selected' : '' }}>{{ y }}</option>
                                {% endfor %}
                            </select>
                            <button class="btn btn-sm btn-success" onclick="loadZI()"><i
                                    class="bi bi-funnel me-1"></i>Filter</button>
                        </div>
                    </div>
                    <div class="section-body no-pad">
                        <div class="table-responsive">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th>Tgl.</th>
                                        <th>Nama</th>
                                        <th>Kontak</th>
                                        <th>Umur</th>
                                        <th>Pendidikan</th>
                                        <th>Pekerjaan</th>
                                        <th>Saran</th>
                                        <th>Layanan</th>
                                        {% for i in 1..13 %}<th class="text-center">K{{ i }}</th>{% endfor %}
                                    </tr>
                                </thead>
                                <tbody id="zi-tbody">
                                    <tr>
                                        <td colspan="22" class="text-center py-4 text-muted">Klik Filter untuk memuat
                                            data.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ═══ Employee Modal ════════════════════════════════════════ -->
<div class="modal fade" id="empModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="emp-modal-title">Tambah Pegawai</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="emp-form" onsubmit="event.preventDefault(); saveEmployee();">
                    <input type="hidden" id="emp-form-id">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Nama Lengkap <span
                                class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" id="emp-f-name" required>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">NIP</label>
                            <input type="text" class="form-control form-control-sm" id="emp-f-nip">
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">NIK</label>
                            <input type="text" class="form-control form-control-sm" id="emp-f-nik">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Jabatan / Posisi</label>
                        <input type="text" class="form-control form-control-sm" id="emp-f-position">
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Tugas</label>
                            <select class="form-select form-select-sm" id="emp-f-job">
                                <option value="">— Pilih —</option>
                                <option value="FO">Front Office</option>
                                <option value="FD">Front Desk</option>
                                <option value="OPR">Operator</option>
                                <option value="NONE">Tidak Ada</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Tgl. Lahir</label>
                            <input type="date" class="form-control form-control-sm" id="emp-f-ttl">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Keterangan / Tentang</label>
                        <input type="text" class="form-control form-control-sm" id="emp-f-about"
                            placeholder="Deskripsi singkat…">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Foto Pegawai</label>
                        <input type="file" class="form-control form-control-sm" id="emp-f-image" accept="image/*">
                        <div class="form-text small text-muted" style="font-size: 0.72rem;">Format: JPG, JPEG, PNG, GIF, WEBP. Maksimal 2MB.</div>
                        <div id="emp-image-preview-container" class="mt-2 d-none">
                            <img id="emp-image-preview" src="" class="rounded border shadow-sm" style="max-height: 80px; object-fit: cover;">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-check-lg me-1"></i>Simpan
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha256-CDOy6cOibCWEdsRiZuaHf8dSGGJRYuBGC+mjoJimHGw=" crossorigin="anonymous"></script>
<script>
    // Baca CSRF token dari meta tag dan inject ke semua fetch request
    const _csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
    const _origFetch = window.fetch;
    window.fetch = function (input, init = {}) {
        const method = (init.method || 'GET').toUpperCase();
        if (['POST', 'PATCH', 'DELETE', 'PUT'].includes(method)) {
            init.headers = Object.assign({ 'X-CSRF-Token': _csrfToken }, init.headers || {});
        }
        return _origFetch(input, init);
    };
</script>
<script src="/assets/js/dashboard.js"></script>
{% endblock %}