{% extends "layout.twig" %}
{% block content %}
<div class="content min-vh-100 py-4 py-md-5 animate-fade-in">
    <div class="container-fluid">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold mb-2" style="font-size: 0.85rem;">Penilaian Pelayanan</span>
            <h1 class="fw-bold text-dark tracking-tight mb-2" style="font-size: 2rem;">
                Beri Nilai Petugas Kami
            </h1>
            <p class="text-secondary mx-auto mb-0" style="max-width: 500px; font-size: 0.95rem;">
                Suara Anda sangat berarti untuk meningkatkan kualitas pelayanan publik di Disdukcapil Kabupaten Tapin.
            </p>
        </div>

        <div class="px-0 px-md-3">
            {% if datas.employee_name %}
            <!-- Employee Card -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5 animate-fade-in" data-pid="{{ datas.employee_id }}">
                <div class="row g-0">
                    <!-- Image Column -->
                    <div class="col-md-5 bg-light d-flex align-items-center justify-content-center p-4" style="min-height: 280px;">
                        <div class="position-relative shadow-sm rounded-4 overflow-hidden" style="width: 200px; height: 200px; border: 4px solid #fff;">
                            {% if datas.employee_image %}
                            <img src="/assets/img/{{ datas.employee_image }}" class="w-100 h-100 object-fit-cover" alt="{{ datas.employee_name }}">
                            {% else %}
                            <img src="/assets/img/EMPLOYEE.jpg" class="w-100 h-100 object-fit-cover" alt="Default Employee Thumbnail">
                            {% endif %}
                        </div>
                    </div>
                    <!-- Details Column -->
                    <div class="col-md-7 d-flex align-items-center">
                        <div class="card-body p-4 p-md-5">
                            <h3 class="fw-bold text-dark mb-1">{{ datas.employee_name }}</h3>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary mb-3 py-2 px-3 fw-medium rounded-pill">{{ datas.employee_about }}</span>
                            
                            <div class="card-text text-start border-top border-light pt-4 mt-2">
                                <p class="text-secondary fw-medium mb-3">Bagaimana kualitas pelayanan yang diberikan oleh petugas ini?</p>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-outline-success py-2.5 px-4 rounded-3 d-flex align-items-center justify-content-center fw-semibold transition-all" data-rate="5">
                                        <i class="bi bi-hand-thumbs-up-fill me-2 fs-5"></i> Bagus / Memuaskan
                                    </button>
                                    <button class="btn btn-outline-primary py-2.5 px-4 rounded-3 d-flex align-items-center justify-content-center fw-semibold transition-all" data-rate="3">
                                        <i class="bi bi-hand-thumbs-up me-2 fs-5"></i> Cukup / Lumayan
                                    </button>
                                    <button class="btn btn-outline-danger py-2.5 px-4 rounded-3 d-flex align-items-center justify-content-center fw-semibold transition-all" data-rate="1">
                                        <i class="bi bi-hand-thumbs-down-fill me-2 fs-5"></i> Kurang / Buruk
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <!-- Not Found State -->
            <div class="card border-0 shadow-sm rounded-4 p-5 text-center mb-5">
                <div class="text-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                </div>
                <h4 class="fw-bold text-dark">Data Tidak Ditemukan</h4>
                <p class="text-secondary mb-0">Petugas yang Anda cari tidak terdaftar atau telah dihapus.</p>
            </div>
            {% endif %}

            <!-- FAQ Section -->
            <div class="bg-white rounded-4 shadow-sm p-4 p-md-5 mb-4 border border-light">
                <h4 class="fw-bold text-dark mb-4 border-start border-4 border-primary ps-3" style="font-size: 1.25rem;">Pertanyaan Umum (FAQ)</h4>
                
                <div class="accordion accordion-flush custom-accordion" id="accordionFlushExample">
                    <!-- FAQ 1 -->
                    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                        <div class="accordion-header" id="flush-headingOne">
                            <button class="accordion-button collapsed bg-light fw-semibold text-dark py-3" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="false"
                                aria-controls="flush-collapseOne">
                                <i class="bi bi-question-circle-fill text-primary me-2 fs-5"></i>
                                Persyaratan & tata cara pembuatan dokumen kependudukan?
                            </button>
                        </div>
                        <div id="flush-collapseOne" class="accordion-collapse collapse"
                            aria-labelledby="flush-headingOne" data-bs-parent="#accordionFlushExample">
                            <div class="accordion-body bg-light pt-0">
                                <div class="p-3 bg-white rounded-3 text-secondary small" style="line-height: 1.6;">
                                    Semua persyaratan lengkap dan tata cara penerbitan berbagai jenis dokumen kependudukan dapat Anda akses dengan mudah pada menu pelayanan kami.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FAQ 2 -->
                    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                        <div class="accordion-header" id="flush-headingTwo">
                            <button class="accordion-button collapsed bg-light fw-semibold text-dark py-3" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseTwo" aria-expanded="false"
                                aria-controls="flush-collapseTwo">
                                <i class="bi bi-question-circle-fill text-primary me-2 fs-5"></i>
                                Cara mengajukan permohonan pengurusan dokumen kependudukan?
                            </button>
                        </div>
                        <div id="flush-collapseTwo" class="accordion-collapse collapse"
                            aria-labelledby="flush-headingTwo" data-bs-parent="#accordionFlushExample">
                            <div class="accordion-body bg-light pt-0">
                                <div class="p-3 bg-white rounded-3 text-secondary small" style="line-height: 1.6;">
                                    Anda dapat mengajukan permohonan pengurusan melalui metode berikut:
                                    <div class="mt-3 ps-3 border-start border-2 border-primary d-grid gap-2">
                                        <div>
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill me-2">1</span>
                                            <strong>Langsung:</strong> Datang langsung ke Kantor Disdukcapil Kab. Tapin pada hari & jam kerja.
                                        </div>
                                        <div>
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill me-2">2</span>
                                            <strong>Online (WhatsApp):</strong> Hubungi nomor Layanan Online resmi kami yang tertera di menu layanan.
                                        </div>
                                        <div>
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill me-2">3</span>
                                            <strong>Melalui Desa:</strong> Gunakan bantuan petugas desa terdekat dari lokasi Anda.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FAQ 3 -->
                    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                        <div class="accordion-header" id="flush-headingThree">
                            <button class="accordion-button collapsed bg-light fw-semibold text-dark py-3" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseThree" aria-expanded="false"
                                aria-controls="flush-collapseThree">
                                <i class="bi bi-question-circle-fill text-primary me-2 fs-5"></i>
                                Tempat pengambilan dokumen yang diajukan online/WhatsApp?
                            </button>
                        </div>
                        <div id="flush-collapseThree" class="accordion-collapse collapse"
                            aria-labelledby="flush-headingThree" data-bs-parent="#accordionFlushExample">
                            <div class="accordion-body bg-light pt-0">
                                <div class="p-3 bg-white rounded-3 text-secondary small" style="line-height: 1.6;">
                                    <div class="ps-3 border-start border-2 border-primary d-grid gap-2">
                                        <div>
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill me-2">1</span>
                                            Diambil di Kantor Dinas Kependudukan dan Pencatatan Sipil setelah Anda menerima pesan notifikasi pengambilan dari petugas kami (bawa berkas persyaratan fisik).
                                        </div>
                                        <div>
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill me-2">2</span>
                                            Menggunakan layanan pengantaran dari PT POS Indonesia langsung ke alamat tujuan.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FAQ 4 -->
                    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                        <div class="accordion-header" id="flush-headingFour">
                            <button class="accordion-button collapsed bg-light fw-semibold text-dark py-3" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseFour" aria-expanded="false"
                                aria-controls="flush-collapseFour">
                                <i class="bi bi-question-circle-fill text-primary me-2 fs-5"></i>
                                Saluran pengaduan permasalahan pelayanan?
                            </button>
                        </div>
                        <div id="flush-collapseFour" class="accordion-collapse collapse"
                            aria-labelledby="flush-headingFour" data-bs-parent="#accordionFlushExample">
                            <div class="accordion-body bg-light pt-0">
                                <div class="p-3 bg-white rounded-3 text-secondary small" style="line-height: 1.6;">
                                    Aspirasi atau pengaduan Anda dapat disampaikan melalui:
                                    <div class="mt-3 ps-3 border-start border-2 border-primary d-grid gap-2">
                                        <div>
                                            <i class="bi bi-mailbox text-primary me-2"></i> Kotak Saran/Pengaduan di Kantor Disdukcapil.
                                        </div>
                                        <div>
                                            <i class="bi bi-whatsapp text-success me-2"></i> WhatsApp Pengaduan: <strong>0811-511-3141</strong>
                                        </div>
                                        <div>
                                            <i class="bi bi-envelope text-danger me-2"></i> Email Pengaduan: <strong>pengaduan@dukcapil.tapinkab.go.id</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FAQ 5 -->
                    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                        <div class="accordion-header" id="flush-headingFive">
                            <button class="accordion-button collapsed bg-light fw-semibold text-dark py-3" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseFive" aria-expanded="false"
                                aria-controls="flush-collapseFive">
                                <i class="bi bi-question-circle-fill text-primary me-2 fs-5"></i>
                                Apakah pengurusan dokumen kependudukan dipungut biaya?
                            </button>
                        </div>
                        <div id="flush-collapseFive" class="accordion-collapse collapse"
                            aria-labelledby="flush-headingFive" data-bs-parent="#accordionFlushExample">
                            <div class="accordion-body bg-light pt-0">
                                <div class="p-3 bg-white rounded-3 text-secondary small" style="line-height: 1.6;">
                                    Seluruh proses pengurusan dokumen kependudukan adalah <strong class="text-danger">GRATIS (Rp0,-)</strong>. Jika ada oknum yang meminta biaya, silakan laporkan segera melalui saluran pengaduan resmi.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FAQ 6 -->
                    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                        <div class="accordion-header" id="flush-headingSix">
                            <button class="accordion-button collapsed bg-light fw-semibold text-dark py-3" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseSix" aria-expanded="false"
                                aria-controls="flush-collapseSix">
                                <i class="bi bi-question-circle-fill text-primary me-2 fs-5"></i>
                                Ketentuan legalisir dokumen kependudukan?
                            </button>
                        </div>
                        <div id="flush-collapseSix" class="accordion-collapse collapse"
                            aria-labelledby="flush-headingSix" data-bs-parent="#accordionFlushExample">
                            <div class="accordion-body bg-light pt-0">
                                <div class="p-3 bg-white rounded-3 text-secondary small" style="line-height: 1.6;">
                                    Dokumen kependudukan format baru yang telah menggunakan tanda tangan digital berupa kode QR (QR Code) tidak memerlukan legalisir fisik/tanda tangan manual lagi.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="/assets/js/rate.js"></script>
{% endblock %}